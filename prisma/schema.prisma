// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  password_hash    String
  name             String
  bio              String?
  default_tone     String          @default("Professional")
  default_language String          @default("en")
  refresh_token    String?         // Stored hashed for rotation/logout
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  social_accounts  SocialAccount[]
  ai_keys          AiKey?
  posts            Post[]
}

model SocialAccount {
  id                String   @id @default(uuid())
  user_id           String
  platform          String   // e.g., "twitter", "linkedin", "instagram"
  access_token_enc  String
  refresh_token_enc String?
  handle            String?
  connected_at      DateTime @default(now())

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, platform]) // A user can only have one connected account per platform
}

model AiKey {
  id                String   @id @default(uuid())
  user_id           String   @unique
  openai_key_enc    String?
  anthropic_key_enc String?
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Post {
  id          String   @id @default(uuid())
  user_id     String
  idea        String   @db.Text
  post_type   String
  tone        String
  language    String
  model_used  String
  status      String   @default("QUEUED") // QUEUED, PARTIAL, COMPLETED, FAILED
  publish_at  DateTime?
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  platforms   PlatformPost[]
}

model PlatformPost {
  id            String    @id @default(uuid())
  post_id       String
  platform      String
  content       String    @db.Text
  status        String    @default("QUEUED") // QUEUED, PROCESSING, PUBLISHED, FAILED, CANCELLED
  published_at  DateTime?
  error_message String?   @db.Text
  attempts      Int       @default(0)

  post          Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
}